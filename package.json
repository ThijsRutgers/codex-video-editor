{
  "name": "video-editor-studio",
  "version": "1.0.0",
  "description": "Autonomous AI video editor powered by Codex + Remotion",
  "scripts": {
    "dev": "npx remotion studio",
    "review": "npm run dev",
    "prepare:review": "npm run transcribe && npm run storyboard:generate && npm run autolabel:people -- --force && npm run storyboard:budget && npm run enrich:people",
    "build": "npm run render",
    "render": "npx tsx scripts/render-with-approval.ts",
    "render:approved": "npm run render -- --yes",
    "render:preview": "npx remotion render MainComposition out/preview.mp4 --crf=28 --scale=0.5",
    "transcribe": "npx tsx scripts/transcribe.ts",
    "storyboard:generate": "npx tsx scripts/generate-storyboard.ts",
    "storyboard:budget": "npx tsx scripts/apply-overlay-budget.ts",
    "autolabel:people": "npx tsx scripts/auto-person-labels.ts",
    "enrich:people": "npx tsx scripts/enrich-person-overlays.ts",
    "project:new": "npx tsx scripts/new-project.ts",
    "review-frame": "npx remotion still MainComposition --output=review-frames/check.png"
  },
  "dependencies": {
    "@remotion/captions": "4.0.435",
    "@remotion/cli": "4.0.435",
    "@remotion/google-fonts": "^4.0.435",
    "@remotion/install-whisper-cpp": "4.0.435",
    "@remotion/webcodecs": "4.0.435",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "4.0.435",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "prettier": "^3.3.0",
    "tailwindcss": "^3.4.0"
  }
}
